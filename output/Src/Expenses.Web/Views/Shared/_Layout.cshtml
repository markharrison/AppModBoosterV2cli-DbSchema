@using Expenses.Web.Services
@inject ApiService Api
@{
    var currentUserId = Context.Session.GetInt32("CurrentUserId");
    var users = await Api.GetUsersAsync();
    var currentUser = users.FirstOrDefault(u => u.UserId == currentUserId);
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Expense Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/">
                    <i class="bi bi-receipt-cutoff me-2"></i>Expense Manager
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="/">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/expenses">
                                <i class="bi bi-wallet2 me-1"></i>My Expenses
                            </a>
                        </li>
                        @if (currentUser?.IsManager == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/approvals">
                                    <i class="bi bi-check-circle me-1"></i>Pending Approvals
                                </a>
                            </li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        <form method="post" action="/set-user" class="d-flex align-items-center">
                            @Html.AntiForgeryToken()
                            <label class="me-2 text-nowrap nav-user-label" for="userSelector">
                                <i class="bi bi-person-circle me-1"></i>User:
                            </label>
                            <select name="userId" id="userSelector" class="form-select form-select-sm user-selector" onchange="this.form.submit()">
                                @foreach (var user in users)
                                {
                                    <option value="@user.UserId" selected="@(user.UserId == currentUserId)">
                                        @user.UserName (@user.Role?.RoleName)
                                    </option>
                                }
                            </select>
                        </form>
                        <button id="themeToggle" class="btn btn-sm theme-toggle-btn" type="button" title="Toggle theme">
                            <i class="bi bi-moon-fill"></i>
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-1"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="app-footer text-center py-3 mt-auto">
        <div class="container">
            <small>&copy; @DateTime.Now.Year Expense Manager</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
