@model List<ExpenseViewModel>
@{
    ViewData["Title"] = "Pending Approvals";
}

<h1 class="fw-bold mb-4">Pending Approvals</h1>

@if (Model.Count == 0)
{
    <div class="text-center py-5">
        <i class="bi bi-check-circle display-1 text-success"></i>
        <h4 class="mt-3">All caught up!</h4>
        <p class="text-muted">No expenses pending your approval.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table app-table align-middle">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Date</th>
                    <th>Category</th>
                    <th>Amount</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var expense in Model.OrderByDescending(e => e.SubmittedAt ?? e.CreatedAt))
                {
                    <tr>
                        <td>@expense.UserName</td>
                        <td>@expense.ExpenseDate.ToString("dd MMM yyyy")</td>
                        <td>@expense.CategoryName</td>
                        <td class="fw-semibold">@expense.FormattedAmount</td>
                        <td class="text-truncate" style="max-width: 250px;">@expense.Description</td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                <a href="/expenses/@expense.ExpenseId" class="btn btn-sm btn-outline-secondary" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form method="post" action="/approvals/@expense.ExpenseId/approve" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-success confirm-action" data-confirm="Approve this expense?" title="Approve">
                                        <i class="bi bi-check-lg"></i> Approve
                                    </button>
                                </form>
                                <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal-@expense.ExpenseId" title="Reject">
                                    <i class="bi bi-x-lg"></i> Reject
                                </button>
                            </div>

                            <!-- Reject Modal -->
                            <div class="modal fade" id="rejectModal-@expense.ExpenseId" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <form method="post" action="/approvals/@expense.ExpenseId/reject">
                                            @Html.AntiForgeryToken()
                                            <div class="modal-header">
                                                <h5 class="modal-title">Reject Expense</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p>Rejecting expense: <strong>@expense.FormattedAmount</strong> — @expense.CategoryName</p>
                                                <div class="mb-3">
                                                    <label for="reason-@expense.ExpenseId" class="form-label">Reason (optional)</label>
                                                    <textarea name="reason" id="reason-@expense.ExpenseId" class="form-control" rows="3" placeholder="Provide a reason for rejection..."></textarea>
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-danger">
                                                    <i class="bi bi-x-lg me-1"></i>Reject
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
