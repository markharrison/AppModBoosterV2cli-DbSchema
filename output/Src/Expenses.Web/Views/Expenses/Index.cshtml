@model List<ExpenseViewModel>
@{
    ViewData["Title"] = "My Expenses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold mb-0">My Expenses</h1>
    <a href="/expenses/create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Expense
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="text-center py-5">
        <i class="bi bi-inbox display-1 text-muted"></i>
        <h4 class="mt-3">No expenses yet</h4>
        <p class="text-muted">Create your first expense to get started.</p>
        <a href="/expenses/create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Create Expense</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table app-table align-middle">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Category</th>
                    <th>Amount</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var expense in Model.OrderByDescending(e => e.ExpenseDate))
                {
                    <tr>
                        <td>@expense.ExpenseDate.ToString("dd MMM yyyy")</td>
                        <td>@expense.CategoryName</td>
                        <td class="fw-semibold">@expense.FormattedAmount</td>
                        <td class="text-truncate" style="max-width: 250px;">@expense.Description</td>
                        <td><span class="badge @expense.StatusBadgeClass">@expense.StatusName</span></td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                <a href="/expenses/@expense.ExpenseId" class="btn btn-sm btn-outline-secondary" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (expense.CanEdit)
                                {
                                    <a href="/expenses/@expense.ExpenseId/edit" class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                }
                                @if (expense.CanSubmit)
                                {
                                    <form method="post" action="/expenses/@expense.ExpenseId/submit" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-success confirm-action" data-confirm="Submit this expense for approval?" title="Submit">
                                            <i class="bi bi-send"></i>
                                        </button>
                                    </form>
                                }
                                @if (expense.CanDelete)
                                {
                                    <form method="post" action="/expenses/@expense.ExpenseId/delete" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger confirm-action" data-confirm="Delete this expense? This cannot be undone." title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
