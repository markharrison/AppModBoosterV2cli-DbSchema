@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

@if (!Model.ApiAvailable)
{
    <div class="text-center py-5">
        <i class="bi bi-exclamation-triangle display-1 text-warning"></i>
        <h2 class="mt-3">Service Temporarily Unavailable</h2>
        <p class="text-muted">The expense management service is warming up. Please try again shortly.</p>
        <a href="/" class="btn btn-primary mt-2"><i class="bi bi-arrow-clockwise me-1"></i>Retry</a>
    </div>
}
else
{
    <div class="mb-4">
        <h1 class="fw-bold">Dashboard</h1>
        <p class="text-muted">Welcome, @Model.CurrentUser?.UserName</p>
    </div>

    <div class="row g-4">
        <div class="col-sm-6 col-lg-3">
            <div class="card dashboard-card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="display-4 fw-bold text-secondary">@Model.Summary.Draft</div>
                    <div class="mt-2 text-muted">Draft</div>
                </div>
                <a href="/expenses" class="card-footer text-decoration-none text-center">View <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card dashboard-card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="display-4 fw-bold text-primary">@Model.Summary.Submitted</div>
                    <div class="mt-2 text-muted">Submitted</div>
                </div>
                <a href="/expenses" class="card-footer text-decoration-none text-center">View <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card dashboard-card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="display-4 fw-bold text-success">@Model.Summary.Approved</div>
                    <div class="mt-2 text-muted">Approved</div>
                </div>
                <a href="/expenses" class="card-footer text-decoration-none text-center">View <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card dashboard-card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="display-4 fw-bold text-danger">@Model.Summary.Rejected</div>
                    <div class="mt-2 text-muted">Rejected</div>
                </div>
                <a href="/expenses" class="card-footer text-decoration-none text-center">View <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>

    @if (Model.IsManager)
    {
        <div class="row g-4 mt-2">
            <div class="col-sm-6 col-lg-3">
                <div class="card dashboard-card h-100 border-0 shadow-sm border-start border-warning border-4">
                    <div class="card-body text-center">
                        <div class="display-4 fw-bold text-warning">@Model.PendingApprovalCount</div>
                        <div class="mt-2 text-muted">Pending Approvals</div>
                    </div>
                    <a href="/approvals" class="card-footer text-decoration-none text-center">Review <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    }
}
